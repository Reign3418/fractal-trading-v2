{
  "name": "fractal-trading-v2",
  "version": "2.0.0",
  "description": "Fractal Node trading engine — v2 ground-up rebuild",
  "main": "dist/server/api.js",
  "scripts": {
    "dev": "tsx watch src/server/api.ts",
    "build": "tsc",
    "start": "node dist/server/api.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ghost": "vitest run tests/doge-ghost.test.ts",
    "seed": "tsx src/scripts/seed.ts",
    "paper-trade": "tsx src/scripts/paper-trade.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "bull": "^4.16.0",
    "ccxt": "^4.3.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "ioredis": "^5.4.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
